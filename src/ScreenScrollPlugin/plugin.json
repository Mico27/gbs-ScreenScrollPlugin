{
  "type": "enginePlugin",
  "name": "Screen Scroll Plugin",
  "author": "Mico27",
  "url": "https://github.com/Mico27/gbs-ScreenScrollPlugin",
  "description": "Adds the ability to scroll the screen between scenes.",
  "license": "MIT",
  "version": "1.0.0",
  "gbsVersion": ">=4.2.2",
  "engineAltRules": [
  {
    "when": {
      "additionalPlugins": ["Mico27/FadeStreetPlugin", "Mico27/MetaTilePlugin", "Mico27/SceneStackExPlugin"]
    },
    "use": "FadeStreetPlugin_MetaTilePlugin_SceneStackExPlugin"
  },
  {
    "when": {
      "additionalPlugins": ["FadeStreetPlugin", "MetaTilePlugin", "SceneStackExPlugin"]
    },
    "use": "FadeStreetPlugin_MetaTilePlugin_SceneStackExPlugin"
  },
  {
    "when": {
      "additionalPlugins": ["Mico27/MetaTilePlugin", "Mico27/SceneStackExPlugin"]
    },
    "use": "MetaTilePlugin_SceneStackExPlugin"
  },
  {
    "when": {
      "additionalPlugins": ["MetaTilePlugin", "SceneStackExPlugin"]
    },
    "use": "MetaTilePlugin_SceneStackExPlugin"
  },
  {
    "when": {
      "additionalPlugins": ["Mico27/FadeStreetPlugin", "Mico27/SceneStackExPlugin"]
    },
    "use": "FadeStreetPlugin_SceneStackExPlugin"
  },
  {
    "when": {
      "additionalPlugins": ["FadeStreetPlugin", "SceneStackExPlugin"]
    },
    "use": "FadeStreetPlugin_SceneStackExPlugin"
  },
  {
    "when": {
      "additionalPlugins": ["Mico27/FadeStreetPlugin", "Mico27/MetaTilePlugin"]
    },
    "use": "FadeStreetPlugin_MetaTilePlugin"
  },
  {
    "when": {
      "additionalPlugins": ["FadeStreetPlugin", "MetaTilePlugin"]
    },
    "use": "FadeStreetPlugin_MetaTilePlugin"
  },
  {
    "when": {
      "additionalPlugins": ["Mico27/SceneStackExPlugin"]
    },
    "use": "SceneStackExPlugin"
  },
  {
    "when": {
      "additionalPlugins": ["SceneStackExPlugin"]
    },
    "use": "SceneStackExPlugin"
  },
  {
    "when": {
      "additionalPlugins": ["Mico27/MetaTilePlugin"]
    },
    "use": "MetaTilePlugin"
  },
  {
    "when": {
      "additionalPlugins": ["MetaTilePlugin"]
    },
    "use": "MetaTilePlugin"
  },
  {
    "when": {
      "additionalPlugins": ["Mico27/FadeStreetPlugin"]
    },
    "use": "FadeStreetPlugin"
  },
  {
    "when": {
      "additionalPlugins": ["FadeStreetPlugin"]
    },
    "use": "FadeStreetPlugin"
  },
  {
    "when": {
      "additionalPlugins": ["Mico27/EditActorActiveIndexPlugin"]
    },
    "use": "EditActorActiveIndexPlugin"
  },
  {
    "when": {
      "additionalPlugins": ["EditActorActiveIndexPlugin"]
    },
    "use": "EditActorActiveIndexPlugin"
  },
  {
    "when": {
      "additionalPlugins": ["Mico27/AppendLoadTextPlugin"]
    },
    "use": "AppendLoadTextPlugin"
  },
  {
    "when": {
      "additionalPlugins": ["AppendLoadTextPlugin"]
    },
    "use": "AppendLoadTextPlugin"
  }]
}
